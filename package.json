{
  "name": "nola-park-inventory-engine",
  "version": "1.0.0",
  "description": "High-performance inventory management system for NOLA City Park with POS integration, weather forecasting, and FSMA 204 compliance",
  "private": true,
  "homepage": "https://github.com/your-org/nola-park-inventory",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/nola-park-inventory.git"
  },
  "author": "Liffort W. Hobley <liffort@nolapark.com>",
  "license": "PROPRIETARY",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "test:supabase-connection": "node scripts/test-supabase.js",
    "test:schema": "node scripts/test-schema.js",
    "test:triggers": "node scripts/test-triggers.js",
    "test:inventory-flow": "jest --testPathPattern=inventory",
    "test:auto-86": "jest --testPathPattern=auto-86",
    "test:forecasting": "jest --testPathPattern=forecast",
    "test:toast-sync": "node scripts/test-toast-sync.js",
    "test:square-sync": "node scripts/test-square-sync.js",
    "test:weather-api": "node scripts/test-weather-api.js",
    "sync:pos": "node scripts/sync-pos-transactions.js",
    "sync:weather": "node scripts/sync-weather.js",
    "sync:forecasts": "node scripts/sync-demand-forecasts.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "type-check": "tsc --noEmit",
    "supabase:pull": "supabase db pull",
    "supabase:push": "supabase db push",
    "supabase:functions:deploy": "supabase functions deploy",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "expo:start": "expo start",
    "expo:android": "eas build --platform android",
    "expo:ios": "eas build --platform ios",
    "deploy:vercel": "vercel --prod",
    "deploy:supabase": "supabase functions deploy",
    "db:migrate": "supabase migration new && supabase db push",
    "db:seed": "node scripts/seed-database.js",
    "precommit": "npm run lint && npm run type-check"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0",
    "@tanstack/react-query": "^5.25.0",
    "@tanstack/query-sync-storage-persister": "^5.25.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.19.0",
    "axios": "^1.6.0",
    "lodash": "^4.17.21",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "react-scripts": "5.0.1",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/user-event": "^14.4.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "eslint": "^8.54.0",
    "eslint-config-react-app": "^7.0.1",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "@types/react": "^18.2.0",
    "@types/node": "^20.10.0",
    "supabase": "^1.109.0"
  },
  "peerDependencies": {
    "react-native": "^0.72.0",
    "expo": "^50.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
