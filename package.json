{
  "name": "nola-park-inventory-engine",
  "version": "1.0.0",
  "description": "High-performance inventory management system for NOLA City Park with POS integration, weather forecasting, and FSMA 204 compliance",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "author": "Liffort W. Hobley <liffort@nolapark.com>",
  "license": "PROPRIETARY",
  "scripts": {
    "start": "expo start --web",
    "build": "npx expo export -p web",
    "test": "react-scripts test",
    "expo:start": "expo start",
    "expo:android": "eas build --platform android",
    "expo:ios": "eas build --platform ios",
    "deploy:vercel": "vercel --prod",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.js\""
  },
  "dependencies": {
    "expo": "~50.0.14",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.73.6",
    "react-native-web": "~0.19.6",
    "@expo/metro-runtime": "~3.1.3",
    "@supabase/supabase-js": "^2.38.0",
    "@tanstack/react-query": "^5.25.0",
    "@tanstack/react-query-persist-client": "^5.25.0",
    "@tanstack/query-sync-storage-persister": "^5.25.0",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "react-native-screens": "~3.29.0",
    "react-native-safe-area-context": "4.8.2",
    "react-native-gesture-handler": "~2.14.0",
    "axios": "^1.6.0",
    "lodash": "^4.17.21",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "react-scripts": "5.0.1",
    "@testing-library/react": "^14.0.0",
    "jest": "^29.7.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0",
    "@types/react": "^18.2.0",
    "supabase": "^1.109.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
