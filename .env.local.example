# ============================================================================
# NOLA CITY PARK INVENTORY ENGINE - ENVIRONMENT TEMPLATE
# ============================================================================
# Copy this file to .env.local and fill in your actual credentials
# IMPORTANT: .env.local is in .gitignore - never commit it!
# Last Updated: March 2, 2026

# ============================================================================
# SUPABASE CONFIGURATION (REQUIRED)
# ============================================================================

# Supabase Project URL
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT_ID > Settings > API
REACT_APP_SUPABASE_URL=https://your-project.supabase.co

# Supabase Anon Key (safe to expose in frontend)
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT_ID > Settings > API
REACT_APP_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role Key (KEEP PRIVATE - server-side only)
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT_ID > Settings > API
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================================================
# OPTIONAL: POS INTEGRATIONS
# ============================================================================

# Toast POS Configuration (if using Toast)
# REACT_APP_TOAST_OAUTH_CLIENT_ID=your_toast_client_id
# REACT_APP_TOAST_OAUTH_CLIENT_SECRET=your_toast_secret
# REACT_APP_TOAST_RESTAURANT_GUID=your_toast_restaurant_guid

# Square Configuration (if using Square)
# REACT_APP_SQUARE_ACCESS_TOKEN=your_square_token
# REACT_APP_SQUARE_APPLICATION_ID=your_app_id
# REACT_APP_SQUARE_APPLICATION_SECRET=your_app_secret

# ============================================================================
# OPTIONAL: WEATHER & FORECASTING
# ============================================================================

# OpenWeather API (for weather-based demand forecasting)
# Sign up at: https://openweathermap.org/api
REACT_APP_OPENWEATHER_API_KEY=your_openweather_api_key
REACT_APP_OPENWEATHER_UNITS=metric

# ============================================================================
# OPTIONAL: NOTIFICATIONS
# ============================================================================

# Twilio Configuration (for SMS alerts)
# Sign up at: https://www.twilio.com/
# REACT_APP_TWILIO_ACCOUNT_SID=your_account_sid
# REACT_APP_TWILIO_AUTH_TOKEN=your_auth_token
# REACT_APP_TWILIO_PHONE_NUMBER=+1234567890

# SendGrid Configuration (for email alerts)
# Sign up at: https://sendgrid.com/
REACT_APP_SENDGRID_API_KEY=your_sendgrid_api_key
REACT_APP_SENDGRID_FROM_EMAIL=alerts@example.com

# ============================================================================
# OPTIONAL: ERROR TRACKING & MONITORING
# ============================================================================

# Sentry (error tracking)
# Sign up at: https://sentry.io/
# REACT_APP_SENTRY_DSN=your_sentry_dsn

# LogRocket (user session replay)
# Sign up at: https://logrocket.com/
# REACT_APP_LOGROCKET_ID=your_logrocket_id

# ============================================================================
# OPTIONAL: PAYMENT PROCESSING
# ============================================================================

# Stripe Configuration (for subscription payments)
# Sign up at: https://stripe.com/
# REACT_APP_STRIPE_PUBLIC_KEY=pk_live_xxxxx

# Lemon Squeezy Configuration (for subscription payments)
# Sign up at: https://www.lemonsqueezy.com/
# REACT_APP_LEMONSQUEEZY_API_KEY=your_api_key
# REACT_APP_LEMONSQUEEZY_STORE_ID=your_store_id

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Node Environment (development, production, test)
NODE_ENV=development

# API Base URL (if different from Supabase)
# REACT_APP_API_BASE_URL=https://your-api.com

# Application Name
REACT_APP_NAME=NOLA City Park Inventory

# Application Version
REACT_APP_VERSION=1.0.0

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/Disable Features
REACT_APP_ENABLE_POS_SYNC=true
REACT_APP_ENABLE_WEATHER_FORECAST=true
REACT_APP_ENABLE_VOICE_AUDITING=true
REACT_APP_ENABLE_AUTO_86=true
REACT_APP_ENABLE_COGS_ANALYSIS=true
REACT_APP_ENABLE_MULTI_LOCATION=true

# ============================================================================
# DEVELOPMENT OPTIONS
# ============================================================================

# Enable Debug Mode
# REACT_APP_DEBUG=false

# Enable Demo Mode (sample data only)
# REACT_APP_DEMO_MODE=false

# Log Level (error, warn, info, debug)
# REACT_APP_LOG_LEVEL=info

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================

# 1. Copy this file:
#    cp .env.local.example .env.local

# 2. Fill in your Supabase credentials:
#    - Get Project URL from Supabase Dashboard > Settings > API
#    - Get Anon Key from Supabase Dashboard > Settings > API

# 3. Add optional API keys for features you want to use:
#    - Toast POS: Get from Toast dashboard
#    - Square: Get from Square developer console
#    - OpenWeather: Get from https://openweathermap.org/api
#    - Twilio: Get from https://www.twilio.com/
#    - SendGrid: Get from https://sendgrid.com/
#    - etc.

# 4. Start the application:
#    npm install
#    npm start

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================

# ⚠️  NEVER commit .env.local to GitHub!
# ⚠️  Always keep secrets in .env.local (not in code)
# ⚠️  Never share your Service Role Key publicly
# ⚠️  Rotate API keys periodically
# ⚠️  Use different keys for development, staging, and production

# For production, use:
# - Supabase Project Settings for environment variables
# - GitHub Secrets for CI/CD pipelines
# - Environment variable services (Vercel, etc.)

